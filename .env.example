# =============================================================================
# Rebase Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets!
# This .env.example file is safe to commit (no real values).
# =============================================================================

# -----------------------------------------------------------------------------
# Cloud Region
# -----------------------------------------------------------------------------
# Change these when migrating from Hong Kong to Guangzhou — no code changes needed.
CLOUD_REGION=cn-hongkong
# Future: CLOUD_REGION=cn-guangzhou

# -----------------------------------------------------------------------------
# Database (PostgreSQL — Alibaba Cloud RDS or local)
# -----------------------------------------------------------------------------
# Full connection string — used by gateway API, scraping pipeline, AND CI features (TASK-01+)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://rebase_app:change_me@localhost:5432/rebase

# Legacy individual vars (kept for reference — DATABASE_URL takes precedence)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=rebase
DATABASE_USER=rebase_app
DATABASE_PASSWORD=change_me_in_dot_env

# -----------------------------------------------------------------------------
# Redis (session cache, agent state)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Object Storage (Alibaba Cloud OSS — uploaded documents)
# -----------------------------------------------------------------------------
OSS_ENDPOINT=oss-cn-hongkong.aliyuncs.com
# Future: OSS_ENDPOINT=oss-cn-guangzhou.aliyuncs.com
OSS_BUCKET=rebase-docs
OSS_ACCESS_KEY_ID=change_me_in_dot_env
OSS_ACCESS_KEY_SECRET=change_me_in_dot_env

# -----------------------------------------------------------------------------
# AI Model APIs
# -----------------------------------------------------------------------------
# Anthropic (Claude) — primary model, accessed from HK server
ANTHROPIC_API_KEY=change_me_in_dot_env
ANTHROPIC_MODEL=claude-opus-4-5

# Backend security — secret token shared between Vercel frontend and ECS backend
# Generate a random string: openssl rand -hex 32
API_SECRET=change_me_in_dot_env

# JWT signing secret — used by gateway/utils/auth.py to sign customer session tokens
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_in_dot_env

# Admin password for customer management endpoints (gateway/routers/customers.py)
# Sent as X-Admin-Password header
ADMIN_SECRET=change_me_in_dot_env

# DeepSeek — secondary model for analysis, classification, reports
DEEPSEEK_API_KEY=change_me_in_dot_env
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qwen (Alibaba) — backup, Chinese language tasks
QWEN_API_KEY=change_me_in_dot_env
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# GLM-4 (Zhipu) — free tier for dev/testing
GLM_API_KEY=change_me_in_dot_env
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# -----------------------------------------------------------------------------
# Dify (intake chatbot platform)
# -----------------------------------------------------------------------------
DIFY_API_URL=http://localhost/v1
DIFY_API_KEY=change_me_in_dot_env

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
# Options: development, staging, production
APP_PORT=8000
APP_DEBUG=true
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Neo4j (workflow graphs)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_dot_env

# -----------------------------------------------------------------------------
# Competitor Intelligence Agent
# -----------------------------------------------------------------------------
# Comma-separated list of competitor names to monitor via Google News RSS
COMPETITORS=competitor1,competitor2,competitor3

# Comma-separated list of email addresses to receive daily reports
REPORT_EMAIL=will@example.com,joanna@example.com

# WeChat Work bot webhook URL for report delivery (optional)
WECHAT_WORK_WEBHOOK=

# Resend API key for email delivery (https://resend.com)
RESEND_API_KEY=change_me_in_dot_env

# -----------------------------------------------------------------------------
# Competitive Intelligence Scraping (services/competitor-intel)
# -----------------------------------------------------------------------------
# Output paths
COMPETITOR_DATA_DIR=frontend/src/data/competitors
COMPETITOR_HTML_DIR=frontend/public

# GitHub push config (for automated scraping pipeline)
GITHUB_REPO=jojosuperstar0506/rebase
GITHUB_TOKEN=change_me_in_dot_env
GIT_BRANCH=main

# Persistent browser profile (recommended — no cookie extraction needed)
# Run setup once: python -m services.competitor-intel.setup_profiles
# Then set this path and leave XHS/DOUYIN/SYCM_COOKIES blank.
# Windows example: C:/rebase-scraper-profile
# Mac example:     /Users/joanna/rebase-scraper-profile
SCRAPER_PROFILE_DIR=

# Platform cookies — alternative to SCRAPER_PROFILE_DIR
# Only needed if NOT using persistent browser profile above.
# Obtain from browser DevTools → Application → Cookies after logging in.
# Cookies expire every 7-14 days and must be refreshed manually.
XHS_COOKIES=
DOUYIN_COOKIES=
SYCM_COOKIES=

# Proxy for scraping (optional, recommended for production)
SCRAPER_PROXY=
