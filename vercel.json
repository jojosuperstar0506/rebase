{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd api && npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/admin/applicants", "destination": "/api/admin" },
    { "source": "/api/admin/approve", "destination": "/api/admin" },
    { "source": "/api/save-survey", "destination": "/api/submit-lead" },
    { "source": "/api/ci/:path*", "destination": "/api/ci?path=:path*" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
